{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RUN_ENDED data",
  "description": "Payload for `type` = RUN_ENDED when `data` is validated standalone.",
  "type": "object",
  "required": ["outcome"],
  "additionalProperties": true,
  "properties": {
    "outcome": {
      "type": "string",
      "description": "Run outcome (e.g. victory, defeat, abandoned)."
    },
    "floor_reached": {
      "type": "integer",
      "minimum": 0,
      "description": "Last floor number reached in the run."
    },
    "score": {
      "type": "integer"
    }
  }
}
