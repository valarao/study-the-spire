{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RELIC_OBTAINED data",
  "description": "Payload for `type` = RELIC_OBTAINED when `data` is validated standalone.",
  "type": "object",
  "required": ["relic_id"],
  "additionalProperties": true,
  "properties": {
    "relic_id": {
      "type": "string",
      "description": "Stable relic identifier when available."
    },
    "relic_name": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "description": "e.g. boss, shop, event"
    }
  }
}
