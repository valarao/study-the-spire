root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[*.{kt,kts}]
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.csproj]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,css}]
indent_style = space
indent_size = 2
